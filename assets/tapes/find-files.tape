# vhs tape: fuzzy find + project grep demo GIF
# run from repo root: vhs assets/tapes/find-files.tape
Output assets/gifs/find-files.gif
Set Shell "bash"
Set FontFamily "JetBrainsMono Nerd Font"
Set FontSize 14
Set Width 1200
Set Height 700
Set Padding 12

Type "nvim"
Enter
Sleep 6s
Type " "
Type " "
Sleep 1.5s
Type "usage"
Sleep 2s
Enter
Sleep 2s
Type " "
Type "/"
Sleep 1.5s
Type "molten"
Sleep 2.5s
Escape
Sleep 500ms
Type ":qa!"
Enter
Sleep 1s
